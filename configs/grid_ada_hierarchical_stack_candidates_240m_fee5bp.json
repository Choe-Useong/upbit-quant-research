{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/ada_hierarchical_stack_candidates_240m_fee5bp",
  "run_name_template": "ada_hierarchical_stack_{short}_{mid}_{long}_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 1
          }
        }
      ],
      "column_name": "sma_1"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 5
          }
        }
      ],
      "column_name": "sma_5"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "compare": {
        "left_feature": "sma_{mid}",
        "operator": "gt",
        "right_feature": "sma_{long}"
      },
      "column_name": "weak_signal"
    },
    {
      "compare": {
        "left_feature": "sma_{short}",
        "operator": "gt",
        "right_feature": "sma_{mid}"
      },
      "column_name": "strong_signal"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "weak_signal",
          "strong_signal"
        ]
      },
      "column_name": "full_signal"
    },
    {
      "components": [
        {
          "feature_column": "weak_signal",
          "weight": 0.5
        },
        {
          "feature_column": "full_signal",
          "weight": 0.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "exposure_score"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "exposure_score",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ADA"
    ],
    "value_filters": [
      {
        "feature_column": "exposure_score",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "feature_value",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-ADA"
  },
  "grid": {
    "short": [
      1,
      5,
      10
    ],
    "mid": [
      20
    ],
    "long": [
      120
    ]
  }
}
