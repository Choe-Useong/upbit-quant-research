{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/ada_ma_10_20_120_persistence_60m_fee5bp",
  "run_name_template": "ada_ma_10_20_120_persist{persist}_60m_every_bar_fee5bp",
  "rolling_ir_windows": [
    365,
    730
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Annualized Information Ratio",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_20"
      },
      "column_name": "ma_10_20"
    },
    {
      "compare": {
        "left_feature": "sma_20",
        "operator": "gt",
        "right_feature": "sma_120"
      },
      "column_name": "ma_20_120"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "ma_10_20",
          "ma_20_120"
        ]
      },
      "column_name": "signal_raw"
    },
    {
      "source": "signal_raw",
      "steps": [
        {
          "kind": "rolling_sum",
          "params": {
            "window": "{persist}"
          }
        }
      ],
      "column_name": "signal_sum{persist}"
    },
    {
      "compare": {
        "left_feature": "signal_sum{persist}",
        "operator": "ge",
        "right_value": "{persist}"
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ADA"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "persist": [
      2,
      3,
      6,
      8,
      12
    ]
  }
}
