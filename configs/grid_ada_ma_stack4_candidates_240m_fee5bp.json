{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/ada_ma_stack4_candidates_240m_fee5bp",
  "run_name_template": "ada_ma_stack4_240m_{short}_{mid1}_{mid2}_{long}_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{short}"
          }
        }
      ],
      "column_name": "sma_{short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{mid1}"
          }
        }
      ],
      "column_name": "sma_{mid1}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{mid2}"
          }
        }
      ],
      "column_name": "sma_{mid2}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{long}"
          }
        }
      ],
      "column_name": "sma_{long}"
    },
    {
      "compare": {
        "left_feature": "sma_{short}",
        "operator": "gt",
        "right_feature": "sma_{mid1}"
      },
      "column_name": "sma{short}_gt_sma{mid1}"
    },
    {
      "compare": {
        "left_feature": "sma_{mid1}",
        "operator": "gt",
        "right_feature": "sma_{mid2}"
      },
      "column_name": "sma{mid1}_gt_sma{mid2}"
    },
    {
      "compare": {
        "left_feature": "sma_{mid2}",
        "operator": "gt",
        "right_feature": "sma_{long}"
      },
      "column_name": "sma{mid2}_gt_sma{long}"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma{short}_gt_sma{mid1}",
          "sma{mid1}_gt_sma{mid2}",
          "sma{mid2}_gt_sma{long}"
        ]
      },
      "column_name": "ma_stack4_{short}_{mid1}_{mid2}_{long}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "ma_stack4_{short}_{mid1}_{mid2}_{long}",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ADA"
    ],
    "value_filters": [
      {
        "feature_column": "ma_stack4_{short}_{mid1}_{mid2}_{long}",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-ADA"
  },
  "grid": {
    "short": [
      1,
      5
    ],
    "mid1": [
      5,
      20
    ],
    "mid2": [
      20,
      60
    ],
    "long": [
      120,
      200
    ]
  },
  "constraints": [
    "short < mid1 < mid2 < long"
  ]
}
