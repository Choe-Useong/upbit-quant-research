{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/ada_score_exposure_candidates_240m_fee5bp",
  "run_name_template": "ada_score_exposure_{a_short}_{a_long}_and_{b_short}_{b_long}_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{a_short}"
          }
        }
      ],
      "column_name": "sma_{a_short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{a_long}"
          }
        }
      ],
      "column_name": "sma_{a_long}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{b_short}"
          }
        }
      ],
      "column_name": "sma_{b_short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{b_long}"
          }
        }
      ],
      "column_name": "sma_{b_long}"
    },
    {
      "compare": {
        "left_feature": "sma_{a_short}",
        "operator": "gt",
        "right_feature": "sma_{a_long}"
      },
      "column_name": "sma{a_short}_gt_sma{a_long}"
    },
    {
      "compare": {
        "left_feature": "sma_{b_short}",
        "operator": "gt",
        "right_feature": "sma_{b_long}"
      },
      "column_name": "sma{b_short}_gt_sma{b_long}"
    },
    {
      "components": [
        {
          "feature_column": "sma{a_short}_gt_sma{a_long}",
          "weight": 0.5
        },
        {
          "feature_column": "sma{b_short}_gt_sma{b_long}",
          "weight": 0.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "exposure_score"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "exposure_score",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ADA"
    ],
    "value_filters": [
      {
        "feature_column": "exposure_score",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "feature_value",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-ADA"
  },
  "grid": {
    "a_short": [
      1,
      5
    ],
    "a_long": [
      20,
      60,
      120
    ],
    "b_short": [
      5,
      10,
      20
    ],
    "b_long": [
      20,
      120,
      200
    ]
  },
  "constraints": [
    "(a_short == 1 and a_long == 20 and b_short == 10 and b_long == 200) or (a_short == 1 and a_long == 120 and b_short == 5 and b_long == 20) or (a_short == 1 and a_long == 60 and b_short == 20 and b_long == 120) or (a_short == 5 and a_long == 20 and b_short == 10 and b_long == 200)"
  ]
}
