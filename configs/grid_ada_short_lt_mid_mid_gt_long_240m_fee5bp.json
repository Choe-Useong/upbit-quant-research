{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/ada_short_lt_mid_mid_gt_long_240m_fee5bp",
  "run_name_template": "ada_short_lt_mid_mid_gt_long_1_20_120_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 1
          }
        }
      ],
      "column_name": "sma_1"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "compare": {
        "left_feature": "sma_1",
        "operator": "lt",
        "right_feature": "sma_20"
      },
      "column_name": "sma1_lt_sma20"
    },
    {
      "compare": {
        "left_feature": "sma_20",
        "operator": "gt",
        "right_feature": "sma_120"
      },
      "column_name": "sma20_gt_sma120"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma1_lt_sma20",
          "sma20_gt_sma120"
        ]
      },
      "column_name": "entry_ok"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "entry_ok",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ADA"
    ],
    "value_filters": [
      {
        "feature_column": "entry_ok",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-ADA"
  },
  "grid": {
    "dummy": [
      1
    ]
  }
}
