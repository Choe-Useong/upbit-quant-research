{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_10_120_momentum_window_filter_60m_fee5bp",
  "run_name_template": "btc_ma_10_120_mom{mom_window}_gt0_60m_{rebalance_frequency}_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Annualized Information Ratio",
  "strategy_metadata_template": {
    "strategy_family": "ma_cross_momentum_filter",
    "strategy_label": "btc_60m_10_120_mom{mom_window}_gt0",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_short_window": 10,
    "parameter_long_window": 120,
    "parameter_momentum_window": "{mom_window}",
    "parameter_momentum_condition": "gt_0",
    "parameter_rebalance_frequency": "{rebalance_frequency}"
  },
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "momentum",
          "params": {
            "window": "{mom_window}"
          }
        }
      ],
      "column_name": "mom_{mom_window}"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_120"
      },
      "column_name": "sma10_gt_sma120"
    },
    {
      "compare": {
        "left_feature": "mom_{mom_window}",
        "operator": "gt",
        "right_value": 0.0
      },
      "column_name": "mom_{mom_window}_gt_0"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma10_gt_sma120",
          "mom_{mom_window}_gt_0"
        ]
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "mom_window": [
      10,
      20,
      60,
      120,
      200,
      400
    ],
    "rebalance_frequency": [
      "every_bar"
    ]
  }
}
