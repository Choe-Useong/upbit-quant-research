{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_ma_10_120_stateful_persistence_60m_fee5bp",
  "run_name_template": "btc_ma_10_120_entrypersist{entry_persist}_exitpersist{exit_persist}_60m_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 5,
  "ranking_metric": "Annualized Information Ratio",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_120"
      },
      "column_name": "entry_raw"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "le",
        "right_feature": "sma_120"
      },
      "column_name": "exit_raw"
    },
    {
      "source": "entry_raw",
      "steps": [
        {
          "kind": "rolling_sum",
          "params": {
            "window": "{entry_persist}"
          }
        }
      ],
      "column_name": "entry_sum_{entry_persist}"
    },
    {
      "compare": {
        "left_feature": "entry_sum_{entry_persist}",
        "operator": "ge",
        "right_value": "{entry_persist}"
      },
      "column_name": "entry_signal"
    },
    {
      "source": "exit_raw",
      "steps": [
        {
          "kind": "rolling_sum",
          "params": {
            "window": "{exit_persist}"
          }
        }
      ],
      "column_name": "exit_sum_{exit_persist}"
    },
    {
      "compare": {
        "left_feature": "exit_sum_{exit_persist}",
        "operator": "ge",
        "right_value": "{exit_persist}"
      },
      "column_name": "exit_signal"
    },
    {
      "state": {
        "entry_feature": "entry_signal",
        "exit_feature": "exit_signal"
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "entry_persist": [
      1,
      3,
      5,
      8
    ],
    "exit_persist": [
      1,
      3,
      5,
      8
    ]
  }
}
