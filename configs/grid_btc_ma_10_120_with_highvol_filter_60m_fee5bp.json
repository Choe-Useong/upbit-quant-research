{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_ma_10_120_with_highvol_filter_60m_fee5bp",
  "run_name_template": "btc_ma_10_120_vol{vol_short}_gt_vol{vol_long}_60m_every_bar_fee5bp",
  "rolling_ir_windows": [
    365,
    730
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Annualized Information Ratio",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "volatility",
          "params": {
            "window": "{vol_short}"
          }
        }
      ],
      "column_name": "vol_{vol_short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "volatility",
          "params": {
            "window": "{vol_long}"
          }
        }
      ],
      "column_name": "vol_{vol_long}"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_120"
      },
      "column_name": "sma10_gt_sma120"
    },
    {
      "compare": {
        "left_feature": "vol_{vol_short}",
        "operator": "gt",
        "right_feature": "vol_{vol_long}"
      },
      "column_name": "vol{vol_short}_gt_vol{vol_long}"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma10_gt_sma120",
          "vol{vol_short}_gt_vol{vol_long}"
        ]
      },
      "column_name": "sma10_gt_sma120__and__vol{vol_short}_gt_vol{vol_long}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "sma10_gt_sma120__and__vol{vol_short}_gt_vol{vol_long}",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "sma10_gt_sma120__and__vol{vol_short}_gt_vol{vol_long}",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "vol_short": [
      24,
      72,
      168
    ],
    "vol_long": [
      72,
      168,
      336
    ]
  },
  "constraints": [
    "vol_short < vol_long"
  ]
}
