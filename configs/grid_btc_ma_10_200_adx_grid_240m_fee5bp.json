{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/btc_ma_10_200_adx_grid_240m_fee5bp",
  "run_name_template": "btc_ma_240m_10_200_adx{adx_window}_gt{adx_threshold}_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 200
          }
        }
      ],
      "column_name": "sma_200"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "adx",
          "params": {
            "window": "{adx_window}"
          }
        }
      ],
      "column_name": "adx_{adx_window}"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_200"
      },
      "column_name": "sma10_gt_sma200"
    },
    {
      "compare": {
        "left_feature": "adx_{adx_window}",
        "operator": "gt",
        "right_value": "{adx_threshold}"
      },
      "column_name": "adx{adx_window}_gt_{adx_threshold}"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma10_gt_sma200",
          "adx{adx_window}_gt_{adx_threshold}"
        ]
      },
      "column_name": "entry_ok"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "entry_ok",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "entry_ok",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "adx_window": [
      10,
      14,
      20
    ],
    "adx_threshold": [
      15,
      20,
      25,
      30
    ]
  }
}
