{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/btc_ma_cross_adx14_gt20_240m_fee5bp",
  "run_name_template": "btc_ma_240m_{short}_{long}_adx14_gt20_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{short}"
          }
        }
      ],
      "column_name": "sma_{short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{long}"
          }
        }
      ],
      "column_name": "sma_{long}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "adx",
          "params": {
            "window": 14
          }
        }
      ],
      "column_name": "adx_14"
    },
    {
      "compare": {
        "left_feature": "sma_{short}",
        "operator": "gt",
        "right_feature": "sma_{long}"
      },
      "column_name": "sma{short}_gt_sma{long}"
    },
    {
      "compare": {
        "left_feature": "adx_14",
        "operator": "gt",
        "right_value": 20
      },
      "column_name": "adx14_gt_20"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma{short}_gt_sma{long}",
          "adx14_gt_20"
        ]
      },
      "column_name": "entry_ok"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "entry_ok",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "entry_ok",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "short": [
      10
    ],
    "long": [
      200
    ]
  }
}
