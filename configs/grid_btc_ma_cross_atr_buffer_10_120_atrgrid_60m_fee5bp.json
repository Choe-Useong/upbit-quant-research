{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_ma_cross_atr_buffer_10_120_atrgrid_60m_fee5bp",
  "run_name_template": "btc_ma_atr_buffer_60m_10_120_atr{atr_window}_k{atr_k}_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 1,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "atr",
          "params": {
            "window": "{atr_window}"
          }
        }
      ],
      "column_name": "atr_{atr_window}"
    },
    {
      "components": [
        {
          "feature_column": "sma_120",
          "weight": 1.0
        },
        {
          "feature_column": "atr_{atr_window}",
          "weight": "{atr_k}"
        }
      ],
      "combine": "weighted_sum",
      "column_name": "sma120_plus_atr{atr_window}_x{atr_k}"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma120_plus_atr{atr_window}_x{atr_k}"
      },
      "column_name": "sma10_gt_sma120_plus_atr{atr_window}_x{atr_k}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "sma10_gt_sma120_plus_atr{atr_window}_x{atr_k}",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "sma10_gt_sma120_plus_atr{atr_window}_x{atr_k}",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "atr_window": [
      5,
      10,
      20
    ],
    "atr_k": [
      0.25,
      0.5,
      1.0
    ]
  }
}
