{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_ma_cross_incremental_20_200_updown_grid_60m_fee5bp",
  "run_name_template": "btc_ma_60m_20_200_incremental_up{step_up}_down{step_down}_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 1,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 200
          }
        }
      ],
      "column_name": "sma_200"
    },
    {
      "compare": {
        "left_feature": "sma_20",
        "operator": "gt",
        "right_feature": "sma_200"
      },
      "column_name": "sma20_gt_sma200"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "sma20_gt_sma200",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ]
  },
  "weight_spec_template": {
    "weighting": "incremental_signal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0,
    "incremental_step_up": "{step_up}",
    "incremental_step_down": "{step_down}",
    "incremental_min_weight": 0.0,
    "incremental_max_weight": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "strategy_metadata_template": {
    "strategy_family": "incremental_signal",
    "strategy_label": "btc_20_200_incremental_up{step_up}_down{step_down}",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_short_window": 20,
    "parameter_long_window": 200,
    "parameter_rebalance_frequency": "every_bar",
    "parameter_incremental_step_up": "{step_up}",
    "parameter_incremental_step_down": "{step_down}",
    "parameter_incremental_min_weight": 0.0,
    "parameter_incremental_max_weight": 1.0
  },
  "grid": {
    "step_up": [
      0.1,
      0.25,
      0.5
    ],
    "step_down": [
      0.25,
      0.5,
      1.0
    ]
  },
  "constraints": [
    "step_down >= step_up"
  ]
}
