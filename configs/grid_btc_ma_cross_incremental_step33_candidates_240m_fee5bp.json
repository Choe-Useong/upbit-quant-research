{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/btc_ma_cross_incremental_step33_candidates_240m_fee5bp",
  "run_name_template": "btc_ma_240m_{short}_{long}_incremental_step33_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{short}"
          }
        }
      ],
      "column_name": "sma_{short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{long}"
          }
        }
      ],
      "column_name": "sma_{long}"
    },
    {
      "compare": {
        "left_feature": "sma_{short}",
        "operator": "gt",
        "right_feature": "sma_{long}"
      },
      "column_name": "sma{short}_gt_sma{long}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "sma{short}_gt_sma{long}",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ]
  },
  "weight_spec_template": {
    "weighting": "incremental_signal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0,
    "incremental_step_size": 0.3333333333333333,
    "incremental_min_weight": 0.0,
    "incremental_max_weight": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "strategy_metadata_template": {
    "strategy_family": "incremental_signal",
    "strategy_label": "btc_{short}_{long}_step33",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_short_window": "{short}",
    "parameter_long_window": "{long}",
    "parameter_rebalance_frequency": "every_bar",
    "parameter_incremental_step_size": 0.3333333333333333,
    "parameter_incremental_min_weight": 0.0,
    "parameter_incremental_max_weight": 1.0
  },
  "grid": {
    "short": [
      1,
      5,
      10,
      20
    ],
    "long": [
      120,
      200
    ]
  },
  "constraints": [
    "short < long"
  ]
}
