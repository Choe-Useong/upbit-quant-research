{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_ma_cross_mom60_below0_60m_fee5bp",
  "run_name_template": "btc_ma_mom60_below0_60m_{short}_{long}_{rebalance_frequency}_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Annualized Information Ratio",
  "strategy_metadata_template": {
    "strategy_family": "ma_cross_momentum_filter",
    "strategy_label": "btc_60m_mom60_below0_{short}_{long}",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_momentum_window": 60,
    "parameter_momentum_condition": "lt_0",
    "parameter_short_window": "{short}",
    "parameter_long_window": "{long}",
    "parameter_rebalance_frequency": "{rebalance_frequency}"
  },
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{short}"
          }
        }
      ],
      "column_name": "sma_{short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": "{long}"
          }
        }
      ],
      "column_name": "sma_{long}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "momentum",
          "params": {
            "window": 60
          }
        }
      ],
      "column_name": "mom_60"
    },
    {
      "compare": {
        "left_feature": "sma_{short}",
        "operator": "gt",
        "right_feature": "sma_{long}"
      },
      "column_name": "sma{short}_gt_sma{long}"
    },
    {
      "compare": {
        "left_feature": "mom_60",
        "operator": "lt",
        "right_value": 0.0
      },
      "column_name": "mom60_lt_0"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma{short}_gt_sma{long}",
          "mom60_lt_0"
        ]
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "short": [
      1,
      3,
      5,
      10,
      20,
      30,
      60
    ],
    "long": [
      10,
      20,
      60,
      120,
      200,
      400
    ],
    "rebalance_frequency": [
      "every_bar"
    ]
  },
  "constraints": [
    "short < long"
  ]
}
