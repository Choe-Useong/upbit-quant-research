{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/btc_ma_stack_5_10_200_240m_fee5bp",
  "run_name_template": "btc_ma_stack_5_10_200_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 1,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 5
          }
        }
      ],
      "column_name": "sma_5"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 200
          }
        }
      ],
      "column_name": "sma_200"
    },
    {
      "compare": {
        "left_feature": "sma_5",
        "operator": "gt",
        "right_feature": "sma_10"
      },
      "column_name": "sma5_gt_sma10"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_200"
      },
      "column_name": "sma10_gt_sma200"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma5_gt_sma10",
          "sma10_gt_sma200"
        ]
      },
      "column_name": "ma_stack_5_10_200"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "ma_stack_5_10_200",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "ma_stack_5_10_200",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "dummy": [
      1
    ]
  }
}
