{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_ma_strict_10_120_plus0p5std120_60m_fee5bp",
  "run_name_template": "btc_ma_strict_10_120_plus0p5std120_60m_{rebalance_frequency}_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Annualized Information Ratio",
  "strategy_metadata_template": {
    "strategy_family": "ma_cross_strict_band",
    "strategy_label": "btc_60m_sma10_gt_sma120_plus_0p5std120",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_short_window": 10,
    "parameter_long_window": 120,
    "parameter_std_window": 120,
    "parameter_sigma_k": 0.5,
    "parameter_rebalance_frequency": "{rebalance_frequency}"
  },
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_std",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "std_120"
    },
    {
      "components": [
        {
          "feature_column": "sma_120",
          "weight": 1.0
        },
        {
          "feature_column": "std_120",
          "weight": 0.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "upper_band"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "upper_band"
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "rebalance_frequency": [
      "every_bar"
    ]
  }
}
