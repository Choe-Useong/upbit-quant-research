{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_mom120_negative_sma20_reversion_entry2p5_exit1_60m_fee5bp",
  "run_name_template": "btc_mom120_neg_sma20_entry2p5std_exit1std_60m_{rebalance_frequency}_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Annualized Information Ratio",
  "strategy_metadata_template": {
    "strategy_family": "mean_reversion_momentum_regime",
    "strategy_label": "btc_60m_mom120_neg_sma20_entry2p5std_exit1std",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_momentum_window": 120,
    "parameter_momentum_condition": "lt_0",
    "parameter_short_window": 20,
    "parameter_anchor_sma_window": 120,
    "parameter_std_window": 120,
    "parameter_entry_std_multiple": 2.5,
    "parameter_exit_std_multiple": 1.0,
    "parameter_rebalance_frequency": "{rebalance_frequency}"
  },
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_std",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "std_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "momentum",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "mom_120"
    },
    {
      "compare": {
        "left_feature": "mom_120",
        "operator": "lt",
        "right_value": 0.0
      },
      "column_name": "mom120_lt_0"
    },
    {
      "components": [
        {
          "feature_column": "sma_120",
          "weight": 1.0
        },
        {
          "feature_column": "std_120",
          "weight": -2.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "entry_band"
    },
    {
      "components": [
        {
          "feature_column": "sma_120",
          "weight": 1.0
        },
        {
          "feature_column": "std_120",
          "weight": -1.0
        }
      ],
      "combine": "weighted_sum",
      "column_name": "exit_band"
    },
    {
      "compare": {
        "left_feature": "sma_20",
        "operator": "lt",
        "right_feature": "entry_band"
      },
      "column_name": "entry_below_band"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "mom120_lt_0",
          "entry_below_band"
        ]
      },
      "column_name": "entry_signal"
    },
    {
      "compare": {
        "left_feature": "sma_20",
        "operator": "gt",
        "right_feature": "exit_band"
      },
      "column_name": "exit_signal"
    },
    {
      "state": {
        "entry_feature": "entry_signal",
        "exit_feature": "exit_signal"
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "rebalance_frequency": [
      "every_bar"
    ]
  }
}
