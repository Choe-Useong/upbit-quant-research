{
  "daily_dir": "data/upbit/daily",
  "out_dir": "data/grid/btc_momentum",
  "run_name_template": "btc_mom{mom_window}_lag{lag}_{rebalance_frequency}",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "momentum",
          "params": {
            "window": "{mom_window}"
          }
        }
      ],
      "column_name": "mom_{mom_window}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "mom_{mom_window}",
    "lag": "{lag}",
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "mom_{mom_window}",
        "operator": "gt",
        "value": 0.0,
        "lag": "{lag}"
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "mom_window": [
      5,
      10,
      20,
      40
    ],
    "lag": [
      1
    ],
    "rebalance_frequency": [
      "daily",
      "weekly"
    ]
  }
}
