{
  "candle_dir": "data/upbit_research/minutes/240",
  "source_cache_dir": "data/upbit_research_cache/240",
  "out_dir": "data/grid/btc_momentum_240m_fee5bp",
  "run_name_template": "btc_mom_240m_{momentum_window}_{rebalance_frequency}_fee5bp",
  "compute_rolling_ir": false,
  "print_run_summaries": false,
  "save_run_artifacts": false,
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "momentum",
          "params": {
            "window": "{momentum_window}"
          }
        }
      ],
      "column_name": "mom_{momentum_window}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "mom_{momentum_window}",
    "lag": 0,
    "signal_lag": 1,
    "start_min_cross_section_size": 1,
    "mode": "all",
    "scope": "filtered",
    "exclude_warnings": true,
    "min_age_days": 180,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "mom_{momentum_window}",
        "operator": "gt",
        "value": 0
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}",
    "universe_name": "{run_name}"
  },
  "vectorbt_spec_template": {
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "momentum_window": [
      1,
      2,
      3,
      4,
      7,
      20,
      30,
      40,
      50,
      80,
      120,
      168
    ],
    "rebalance_frequency": [
      "every_bar"
    ]
  }
}
