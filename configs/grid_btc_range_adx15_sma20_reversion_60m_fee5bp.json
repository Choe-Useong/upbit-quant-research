{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_range_adx15_sma20_reversion_60m_fee5bp",
  "run_name_template": "btc_range_adx15_sma20_entry1p5std_exitmean_60m_{rebalance_frequency}_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Annualized Information Ratio",
  "strategy_metadata_template": {
    "strategy_family": "range_reversion",
    "strategy_label": "btc_60m_adx14_lt15_sma20_entry1p5std_exitmean",
    "asset_scope": "BTC"
  },
  "parameter_metadata_template": {
    "parameter_adx_window": 14,
    "parameter_adx_threshold": 15,
    "parameter_mean_window": 20,
    "parameter_std_window": 20,
    "parameter_entry_std_multiple": 1.5,
    "parameter_rebalance_frequency": "{rebalance_frequency}"
  },
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_std",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "std_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "adx",
          "params": {
            "window": 14
          }
        }
      ],
      "column_name": "adx_14"
    },
    {
      "compare": {
        "left_feature": "adx_14",
        "operator": "lt",
        "right_value": 15.0
      },
      "column_name": "range_regime"
    },
    {
      "components": [
        {
          "feature_column": "sma_20",
          "weight": 1.0
        },
        {
          "feature_column": "std_20",
          "weight": -1.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "entry_band"
    },
    {
      "compare": {
        "left_feature": "trade_price",
        "operator": "lt",
        "right_feature": "entry_band"
      },
      "column_name": "entry_below_band"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "range_regime",
          "entry_below_band"
        ]
      },
      "column_name": "entry_signal"
    },
    {
      "compare": {
        "left_feature": "trade_price",
        "operator": "gt",
        "right_feature": "sma_20"
      },
      "column_name": "exit_to_mean"
    },
    {
      "logical": {
        "operator": "not",
        "features": [
          "range_regime"
        ]
      },
      "column_name": "regime_off"
    },
    {
      "logical": {
        "operator": "or",
        "features": [
          "exit_to_mean",
          "regime_off"
        ]
      },
      "column_name": "exit_signal"
    },
    {
      "state": {
        "entry_feature": "entry_signal",
        "exit_feature": "exit_signal"
      },
      "column_name": "signal"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "signal",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "signal",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "rebalance_frequency": [
      "every_bar"
    ]
  }
}
