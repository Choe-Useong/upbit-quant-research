{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/btc_vol_cross_longcash_60m_fee5bp",
  "run_name_template": "btc_vol{short}_lt_vol{long}_60m_every_bar_fee5bp",
  "rolling_ir_windows": [
    365,
    730
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Annualized Information Ratio",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "volatility",
          "params": {
            "window": "{short}"
          }
        }
      ],
      "column_name": "vol_{short}"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "volatility",
          "params": {
            "window": "{long}"
          }
        }
      ],
      "column_name": "vol_{long}"
    },
    {
      "compare": {
        "left_feature": "vol_{short}",
        "operator": "lt",
        "right_feature": "vol_{long}"
      },
      "column_name": "vol{short}_lt_vol{long}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "vol{short}_lt_vol{long}",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-BTC"
    ],
    "value_filters": [
      {
        "feature_column": "vol{short}_lt_vol{long}",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "short": [
      24,
      72,
      168
    ],
    "long": [
      72,
      168,
      336
    ]
  },
  "constraints": [
    "short < long"
  ]
}
