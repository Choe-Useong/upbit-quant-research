{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/eth_score_exposure_5_60_and_3_400_60m_fee5bp",
  "run_name_template": "eth_score_exposure_5_60_and_3_400_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 1,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 3
          }
        }
      ],
      "column_name": "sma_3"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 5
          }
        }
      ],
      "column_name": "sma_5"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 60
          }
        }
      ],
      "column_name": "sma_60"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 400
          }
        }
      ],
      "column_name": "sma_400"
    },
    {
      "compare": {
        "left_feature": "sma_5",
        "operator": "gt",
        "right_feature": "sma_60"
      },
      "column_name": "sma5_gt_sma60"
    },
    {
      "compare": {
        "left_feature": "sma_3",
        "operator": "gt",
        "right_feature": "sma_400"
      },
      "column_name": "sma3_gt_sma400"
    },
    {
      "components": [
        {
          "feature_column": "sma5_gt_sma60",
          "weight": 0.5
        },
        {
          "feature_column": "sma3_gt_sma400",
          "weight": 0.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "exposure_score"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "exposure_score",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ETH"
    ],
    "value_filters": [
      {
        "feature_column": "exposure_score",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "feature_value",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-ETH"
  },
  "grid": {
    "dummy": [
      1
    ]
  }
}
