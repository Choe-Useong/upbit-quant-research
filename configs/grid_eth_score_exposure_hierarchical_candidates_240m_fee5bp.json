{
  "candle_dir": "data/upbit/minutes/240",
  "timeframe": "240m",
  "out_dir": "data/grid/eth_score_exposure_hierarchical_candidates_240m_fee5bp",
  "run_name_template": "eth_score_exposure_hier_{weak_short}_{weak_long}_then_{strong_short}_{strong_long}_every_bar_fee5bp",
  "rolling_ir_windows": [
    126,
    252
  ],
  "save_rolling_ir_plots": true,
  "top_curve_count": 5,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 1
          }
        }
      ],
      "column_name": "sma_1"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 5
          }
        }
      ],
      "column_name": "sma_5"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 200
          }
        }
      ],
      "column_name": "sma_200"
    },
    {
      "compare": {
        "left_feature": "sma_{weak_short}",
        "operator": "gt",
        "right_feature": "sma_{weak_long}"
      },
      "column_name": "weak_signal"
    },
    {
      "compare": {
        "left_feature": "sma_{strong_short}",
        "operator": "gt",
        "right_feature": "sma_{strong_long}"
      },
      "column_name": "strong_signal"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "weak_signal",
          "strong_signal"
        ]
      },
      "column_name": "full_signal"
    },
    {
      "components": [
        {
          "feature_column": "weak_signal",
          "weight": 0.5
        },
        {
          "feature_column": "full_signal",
          "weight": 0.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "exposure_score"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "exposure_score",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-ETH"
    ],
    "value_filters": [
      {
        "feature_column": "exposure_score",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "feature_value",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-ETH"
  },
  "grid": {
    "weak_short": [
      1,
      5,
      10
    ],
    "weak_long": [
      120,
      200
    ],
    "strong_short": [
      5,
      10,
      20
    ],
    "strong_long": [
      20,
      120,
      200
    ]
  },
  "constraints": [
    "((weak_short == 1 and weak_long == 120) or (weak_short == 1 and weak_long == 200) or (weak_short == 5 and weak_long == 120) or (weak_short == 5 and weak_long == 200) or (weak_short == 10 and weak_long == 200))",
    "((strong_short == 5 and strong_long == 20) or (strong_short == 10 and strong_long == 120) or (strong_short == 20 and strong_long == 200))",
    "strong_long <= weak_long",
    "not (weak_short == strong_short and weak_long == strong_long)"
  ]
}
