{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/sol_logprice_ma_stack_candidates_60m_fee5bp",
  "run_name_template": "sol_logprice_ma_stack_60m_{short}_{mid}_{long}_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        { "kind": "log", "params": { "mode": "log" } },
        { "kind": "rolling_mean", "params": { "window": "{short}" } }
      ],
      "column_name": "logsma_{short}"
    },
    {
      "source": "trade_price",
      "steps": [
        { "kind": "log", "params": { "mode": "log" } },
        { "kind": "rolling_mean", "params": { "window": "{mid}" } }
      ],
      "column_name": "logsma_{mid}"
    },
    {
      "source": "trade_price",
      "steps": [
        { "kind": "log", "params": { "mode": "log" } },
        { "kind": "rolling_mean", "params": { "window": "{long}" } }
      ],
      "column_name": "logsma_{long}"
    },
    {
      "compare": {
        "left_feature": "logsma_{short}",
        "operator": "gt",
        "right_feature": "logsma_{mid}"
      },
      "column_name": "logsma{short}_gt_logsma{mid}"
    },
    {
      "compare": {
        "left_feature": "logsma_{mid}",
        "operator": "gt",
        "right_feature": "logsma_{long}"
      },
      "column_name": "logsma{mid}_gt_logsma{long}"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "logsma{short}_gt_logsma{mid}",
          "logsma{mid}_gt_logsma{long}"
        ]
      },
      "column_name": "log_ma_stack_{short}_{mid}_{long}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "log_ma_stack_{short}_{mid}_{long}",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": ["KRW-SOL"],
    "value_filters": [
      {
        "feature_column": "log_ma_stack_{short}_{mid}_{long}",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-SOL"
  },
  "grid": {
    "short": [5, 10, 20],
    "mid": [60, 120],
    "long": [200, 400]
  },
  "constraints": ["short < mid < long"]
}
