{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/sol_ma_stack_5_60_300_60m_fee5bp",
  "run_name_template": "sol_ma_stack_60m_5_60_300_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 0,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 5
          }
        }
      ],
      "column_name": "sma_5"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 60
          }
        }
      ],
      "column_name": "sma_60"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 300
          }
        }
      ],
      "column_name": "sma_300"
    },
    {
      "compare": {
        "left_feature": "sma_5",
        "operator": "gt",
        "right_feature": "sma_60"
      },
      "column_name": "sma5_gt_sma60"
    },
    {
      "compare": {
        "left_feature": "sma_60",
        "operator": "gt",
        "right_feature": "sma_300"
      },
      "column_name": "sma60_gt_sma300"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma5_gt_sma60",
          "sma60_gt_sma300"
        ]
      },
      "column_name": "ma_stack_5_60_300"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "ma_stack_5_60_300",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-SOL"
    ],
    "value_filters": [
      {
        "feature_column": "ma_stack_5_60_300",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar"
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-SOL"
  },
  "grid": {
    "dummy": [
      1
    ]
  }
}
