{
  "candle_dir": "data/upbit_research/minutes/60",
  "out_dir": "data/grid/upbit_turnover_only_60m_fee5bp",
  "run_name_template": "upbit_turn{turnover_hours}_q1_{rebalance_frequency}_startcs{start_min_cross_section_size}_age{min_age_days}_fee5bp",
  "shared_feature_spec_template": [
    {
      "source": "candle_acc_trade_price",
      "steps": [
        {
          "kind": "rolling_sum",
          "params": {
            "window": 24
          }
        }
      ],
      "column_name": "turnover_24h"
    },
    {
      "source": "candle_acc_trade_price",
      "steps": [
        {
          "kind": "rolling_sum",
          "params": {
            "window": 48
          }
        }
      ],
      "column_name": "turnover_48h"
    },
    {
      "source": "candle_acc_trade_price",
      "steps": [
        {
          "kind": "rolling_sum",
          "params": {
            "window": 72
          }
        }
      ],
      "column_name": "turnover_72h"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "age_days"
        }
      ],
      "column_name": "age_days"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "turnover_{turnover_hours}h",
    "lag": 0,
    "signal_lag": 1,
    "start_min_cross_section_size": "{start_min_cross_section_size}",
    "mode": "top_n",
    "top_n": 999,
    "ascending": false,
    "exclude_warnings": true,
    "min_age_days": "{min_age_days}",
    "excluded_markets": [
      "KRW-BTC",
      "KRW-ETH",
      "KRW-XRP",
      "KRW-ADA",
      "KRW-DOGE",
      "KRW-SOL",
      "KRW-AVAX"
    ],
    "rank_filters": [
      {
        "feature_column": "turnover_{turnover_hours}h",
        "mode": "quantile",
        "lag": 0,
        "quantiles": 5,
        "bucket_values": [
          1
        ],
        "ascending": true
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}",
    "universe_name": "{run_name}"
  },
  "vectorbt_spec_template": {
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "turnover_hours": [
      24,
      48,
      72
    ],
    "rebalance_frequency": [
      "daily",
      "every_bar"
    ],
    "start_min_cross_section_size": [
      50,
      100
    ],
    "min_age_days": [
      180,
      365
    ]
  }
}
