{
  "candle_dir": "data/upbit_research/minutes/240",
  "source_cache_dir": "data/upbit_research_cache/240",
  "out_dir": "data/grid/upbit_turnrank180d_cutq4_turnq4_momq4_240m_fee5bp",
  "run_name_template": "upbit_240m_turncutq4_turnq{turnover_bucket}_momq{momentum_bucket}_momw{momentum_window}_{rebalance_frequency}_age{min_age_days}_fee5bp",
  "compute_rolling_ir": false,
  "print_run_summaries": false,
  "save_run_artifacts": false,
  "shared_feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "age_days"
        }
      ],
      "column_name": "age_days"
    },
    {
      "preset": "turnover_rank_persist",
      "params": {
        "avg_window": 1080
      },
      "column_name": "turn_rank_1bar_180d_avg"
    }
  ],
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "momentum",
          "params": {
            "window": "{momentum_window}"
          }
        }
      ],
      "column_name": "mom_{momentum_window}"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "turn_rank_1bar_180d_avg",
    "lag": 0,
    "signal_lag": 1,
    "start_min_cross_section_size": 50,
    "mode": "all",
    "scope": "filtered",
    "exclude_warnings": true,
    "min_age_days": "{min_age_days}",
    "filter_stages": [
      {
        "mode": "sequential",
        "filters": [
          {
            "feature_column": "turn_rank_1bar_180d_avg",
            "mode": "quantile",
            "lag": 0,
            "quantiles": 4,
            "bucket_values": [
              1,
              2,
              3
            ],
            "ascending": false,
            "scope": "filtered"
          }
        ]
      },
      {
        "mode": "and",
        "filters": [
          {
            "feature_column": "turn_rank_1bar_180d_avg",
            "mode": "quantile",
            "lag": 0,
            "quantiles": 4,
            "bucket_values": [
              "{turnover_bucket}"
            ],
            "ascending": false,
            "scope": "filtered"
          },
          {
            "feature_column": "mom_{momentum_window}",
            "mode": "quantile",
            "lag": 0,
            "quantiles": 4,
            "bucket_values": [
              "{momentum_bucket}"
            ],
            "ascending": false,
            "scope": "filtered"
          }
        ]
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "equal",
    "gross_exposure": 1.0,
    "rebalance_frequency": "{rebalance_frequency}",
    "universe_name": "{run_name}"
  },
  "vectorbt_spec_template": {
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-BTC"
  },
  "grid": {
    "turnover_bucket": [
      1,
      2,
      3,
      4
    ],
    "momentum_bucket": [
      1,
      2,
      3,
      4
    ],
    "momentum_window": [
      18,
      42,
      84,
      168
    ],
    "rebalance_frequency": [
      "every_bar"
    ],
    "min_age_days": [
      180
    ]
  }
}
