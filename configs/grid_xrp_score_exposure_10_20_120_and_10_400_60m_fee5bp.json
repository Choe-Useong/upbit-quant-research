{
  "candle_dir": "data/upbit/minutes/60",
  "timeframe": "60m",
  "out_dir": "data/grid/xrp_score_exposure_10_20_120_and_10_400_60m_fee5bp",
  "run_name_template": "xrp_score_exposure_60m_10_20_120_and_10_400_every_bar_fee5bp",
  "compute_rolling_ir": false,
  "save_summary_plots": false,
  "save_rolling_ir_plots": false,
  "top_curve_count": 1,
  "ranking_metric": "Total Return [%]",
  "feature_spec_template": [
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 10
          }
        }
      ],
      "column_name": "sma_10"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 20
          }
        }
      ],
      "column_name": "sma_20"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 120
          }
        }
      ],
      "column_name": "sma_120"
    },
    {
      "source": "trade_price",
      "steps": [
        {
          "kind": "rolling_mean",
          "params": {
            "window": 400
          }
        }
      ],
      "column_name": "sma_400"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_20"
      },
      "column_name": "sma10_gt_sma20"
    },
    {
      "compare": {
        "left_feature": "sma_20",
        "operator": "gt",
        "right_feature": "sma_120"
      },
      "column_name": "sma20_gt_sma120"
    },
    {
      "logical": {
        "operator": "and",
        "features": [
          "sma10_gt_sma20",
          "sma20_gt_sma120"
        ]
      },
      "column_name": "ma_stack_10_20_120"
    },
    {
      "compare": {
        "left_feature": "sma_10",
        "operator": "gt",
        "right_feature": "sma_400"
      },
      "column_name": "sma10_gt_sma400"
    },
    {
      "components": [
        {
          "feature_column": "ma_stack_10_20_120",
          "weight": 0.5
        },
        {
          "feature_column": "sma10_gt_sma400",
          "weight": 0.5
        }
      ],
      "combine": "weighted_sum",
      "column_name": "score_10_20_120_and_10_400"
    }
  ],
  "universe_spec_template": {
    "name": "{run_name}",
    "feature_column": "score_10_20_120_and_10_400",
    "lag": 1,
    "mode": "top_n",
    "top_n": 1,
    "ascending": false,
    "allowed_markets": [
      "KRW-XRP"
    ],
    "value_filters": [
      {
        "feature_column": "score_10_20_120_and_10_400",
        "operator": "gt",
        "value": 0.0,
        "lag": 1
      }
    ]
  },
  "weight_spec_template": {
    "weighting": "feature_value",
    "gross_exposure": 1.0,
    "rebalance_frequency": "every_bar",
    "feature_value_scale": 1.0,
    "feature_value_clip_min": 0.0,
    "feature_value_clip_max": 1.0
  },
  "vectorbt_spec_template": {
    "price_column": "trade_price",
    "init_cash": 1000000.0,
    "fees": 0.0005,
    "slippage": 0.0,
    "benchmark_market": "KRW-XRP"
  },
  "grid": {}
}
